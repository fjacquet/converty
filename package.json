{
  "name": "converty",
  "version": "1.0.0",
  "description": "Web-based calculator and converter collection",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "fetch-crypto-prices": "npx tsx scripts/fetch-crypto-prices.ts",
    "fetch-mining-data": "npx tsx scripts/fetch-mining-data.ts",
    "fetch-spec-cpu-data": "npx tsx scripts/fetch-spec-cpu-data.ts",
    "prebuild": "npx tsx scripts/fetch-crypto-prices.ts && npx tsx scripts/fetch-mining-data.ts && npx tsx scripts/fetch-spec-cpu-data.ts && npx tsx scripts/generate-search-index.ts",
    "build:next": "next build",
    "build": "npm run prebuild && next build && node scripts/generate-sw.js",
    "start": "next start",
    "lint": "eslint .",
    "lint:biome": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "type-check": "tsc --noEmit",
    "quality": "npm run lint && npm run lint:biome && npm run type-check",
    "package": "node scripts/package-local.js",
    "prepare": "husky",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "calculator",
    "converter",
    "tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@swc/helpers": "^0.5.18",
    "@tailwindcss/postcss": "^4.1.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "crypto-js": "^4.2.0",
    "fuse.js": "^7.1.0",
    "ipaddr.js": "^2.3.0",
    "isomorphic-dompurify": "^3.0.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.562.0",
    "lz-string": "^1.5.0",
    "next": "^16.1.1",
    "next-intl": "^4.7.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-error-boundary": "^6.1.1",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "wallet-address-validator": "^0.2.4",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@eslint/js": "^9.39.2",
    "@lingual/i18n-check": "^0.8.19",
    "@next/bundle-analyzer": "^16.1.3",
    "@next/eslint-plugin-next": "^16.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.0.6",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "workbox-build": "^7.4.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "rollup@2": "^2.80.0"
  }
}
